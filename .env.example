# === SECRET PARAMETERS ===
# Non-secret settings live in src/config/config.yaml

# Telegram Bot Token
# Get a token from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# === ADMINISTRATORS ===
# Telegram user IDs of the bot admins (comma-separated)
# Find your ID with @userinfobot in Telegram
ADMIN_IDS=123456789

# ============================================================================
# PROVIDERS (Auto-Discovery)
# ============================================================================
# Providers are auto-discovered from the shape of the variable names!
# No configuration in config.yaml is required.
#
# Patterns:
#   HETZNER_{SUFFIX}_API_KEY       -> alias=hetzner_{suffix}
#   VULTR_{SUFFIX}_API_KEY         -> alias=vultr_{suffix}
#   AWS_{SUFFIX}_ACCESS_KEY_ID +
#   AWS_{SUFFIX}_SECRET_ACCESS_KEY -> alias=aws_{suffix}
#
# Generated automatically:
#   - display_name: "Hetzner (suffix)", "Vultr", "AWS (suffix)"
#     (if suffix="main", simply "Hetzner", "Vultr", "AWS")
#   - emoji: [H] for Hetzner, [V] for Vultr, [A] for AWS
#   - AWS: regions=null (all regions), enable_ec2=true, enable_lightsail=true

# --- Hetzner Cloud ---
# Get one in the Hetzner Cloud Console: https://console.hetzner.cloud/
# Examples:
#   HETZNER_PROD_API_KEY -> alias=hetzner_prod, display="Hetzner (prod)"
#   HETZNER_STAGING_API_KEY    -> alias=hetzner_staging, display="Hetzner (staging)"
#   HETZNER_MAIN_API_KEY   -> alias=hetzner_main, display="Hetzner"
HETZNER_PROD_API_KEY=
HETZNER_STAGING_API_KEY=

# --- Vultr ---
# Get one in your Vultr account settings: https://my.vultr.com/settings/#settingsapi
# Examples:
#   VULTR_MAIN_API_KEY -> alias=vultr_main, display="Vultr"
#   VULTR_PROD_API_KEY -> alias=vultr_prod, display="Vultr (prod)"
VULTR_MAIN_API_KEY=

# --- AWS ---
# Create an IAM user with permissions: EC2, Lightsail, Cost Explorer (optional)
# https://console.aws.amazon.com/iam/
# IMPORTANT: BOTH keys are required for the provider to be discovered!
# Examples:
#   AWS_MAIN_ACCESS_KEY_ID + AWS_MAIN_SECRET_ACCESS_KEY -> alias=aws_main, display="AWS"
#   AWS_PROD_ACCESS_KEY_ID + AWS_PROD_SECRET_ACCESS_KEY -> alias=aws_prod, display="AWS (prod)"
AWS_MAIN_ACCESS_KEY_ID=
AWS_MAIN_SECRET_ACCESS_KEY=
